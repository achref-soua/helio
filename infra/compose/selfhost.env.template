# Helio configuration. The installer (`helio install`) fills every
# __GENERATE_*__ marker with a fresh random value — markers sharing the
# same name receive the same value (so connection strings stay in sync).
# Edit anything else freely; `helio update` only ever APPENDS new keys.

# ── Profile ────────────────────────────────────────────────────────────────
# core = dashboard + API + AI (≈2.5 GB RAM). full adds campaign/journey
# delivery, event ingestion, tracking, and analytics (≈8 GB RAM hosts).
COMPOSE_PROFILES=core

# ── Public addresses ───────────────────────────────────────────────────────
# Where users reach the dashboard (used in auth callbacks and email links).
APP_URL=http://localhost:3000
WEB_PORT=3000
API_PORT=4000
MAILPIT_UI_PORT=8025
INGEST_PORT=4100
TRACKING_PORT=4200
# Public base URL for open/click tracking links (full profile).
PUBLIC_TRACKING_URL=http://localhost:4200

# ── Datastores (inside the Docker network — not exposed to the host) ──────
POSTGRES_USER=helio
POSTGRES_DB=helio
POSTGRES_PASSWORD=__GENERATE_PASSWORD_PG__
# The RLS-bound application role's password (synced by the migrate job).
HELIO_APP_DB_PASSWORD=__GENERATE_PASSWORD_APP__
CLICKHOUSE_USER=helio
CLICKHOUSE_DB=helio
CLICKHOUSE_PASSWORD=__GENERATE_PASSWORD_CH__

# ── Secrets (unique to this installation) ──────────────────────────────────
# Session/token signing.
BETTER_AUTH_SECRET=__GENERATE_HEX32_AUTH__
# Signs one-click unsubscribe tokens.
UNSUBSCRIBE_SECRET=__GENERATE_HEX24_UNSUB__
# Binds click-redirect targets to their send.
TRACKING_SECRET=__GENERATE_HEX24_TRACK__
# Seals per-organization provider credentials at rest (AES-256-GCM).
# Losing this key means re-entering stored credentials — keep it with
# your backups. Rotation: `helio rotate-key`.
HELIO_ENCRYPTION_KEY=__GENERATE_B64_VAULT__
# Set only during `helio rotate-key`; removed when the walk finishes.
# HELIO_ENCRYPTION_KEY_PREVIOUS=

# ── Inbound webhooks (optional — enable per provider) ─────────────────────
# Bounce/complaint suppression: configure your email provider to POST to
#   <api>/webhooks/email/{postmark|ses}?token=<this value>
EMAIL_WEBHOOK_TOKEN=__GENERATE_HEX24_EMAILWH__
# Twilio delivery-status callback: <api>/webhooks/sms/twilio?token=<this>
SMS_WEBHOOK_TOKEN=__GENERATE_HEX24_SMSWH__

# ── Web push (optional) ────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=__GENERATE_VAPID_PUBLIC__
VAPID_PRIVATE_KEY=__GENERATE_VAPID_PRIVATE__

# ── Journey outbound webhooks (optional) ───────────────────────────────────
WEBHOOK_SIGNING_SECRET=__GENERATE_HEX24_JOURNEYWH__

# ── Email fallback ─────────────────────────────────────────────────────────
# Organizations connect their real provider in Settings → Provider
# credentials; until then mail lands in the bundled Mailpit test inbox
# (http://localhost:8025) and never reaches real recipients.
MAIL_FROM=Helio <no-reply@helio.local>

# ── AI fallback (optional) ─────────────────────────────────────────────────
# Organizations can paste their own AI key in Settings; these serve anyone
# who hasn't. Leave the key empty to disable the deployment fallback.
INTEL_LLM_PROVIDER=groq
INTEL_LLM_MODEL=llama-3.3-70b-versatile
INTEL_LLM_API_KEY=

# ── Backups ────────────────────────────────────────────────────────────────
# Nightly local database backups land in this folder (relative paths are
# inside the Helio directory). Restore: helio restore <file>.
HELIO_BACKUPS_PATH=./backups
# How many backups to keep, and when (UTC, HH:MM) the nightly one runs.
BACKUP_KEEP=14
BACKUP_TIME=03:30
# Optional: encrypt backups with a passphrase (aes-256). If you lose the
# passphrase the backups are unrecoverable — store it with your .env copy.
# BACKUP_PASSPHRASE=

# ── Updates ────────────────────────────────────────────────────────────────
# The dashboard checks GitHub's public releases feed (anonymous, cached,
# sends nothing) and shows a notice in Settings → About. false disables.
HELIO_UPDATE_CHECK=true
# One-click in-app updates. When true (and the `update` profile is active,
# which the installer turns on), the owner can update the whole instance from
# Settings → Updates. This runs a small sidecar that holds the Docker socket
# to recreate the stack — see SECURITY.md. Set false to hide the button;
# dropping `update` from COMPOSE_PROFILES removes the sidecar (and the socket)
# entirely. The terminal `helio update` works regardless of this setting.
HELIO_INAPP_UPDATE=false
# Authorizes the dashboard's request to the update sidecar (installer-set;
# shared between the web and updater services only).
HELIO_UPDATE_SECRET=__GENERATE_HEX32_UPDATE__
