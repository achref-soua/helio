# ──────────────────────────────────────────────────────────────────────
# Helio environment configuration
#
# Copy to `.env` and adjust:   cp .env.example .env
#
# Every variable read by any Helio service is documented here, in the
# same PR that introduces it. Variables marked [required] have no
# default and make the owning service fail fast at startup.
# ──────────────────────────────────────────────────────────────────────

# Node environment: development | test | production  (default: development)
# NODE_ENV=development

# ── PostgreSQL (compose service: postgres) ─────────────────────────────
# Credentials for the local container; change for any non-dev deployment.
POSTGRES_USER=helio
POSTGRES_PASSWORD=helio_dev_password
POSTGRES_DB=helio
POSTGRES_PORT=5432

# Runtime connection [required by app services]. Uses the helio_app role,
# which is subject to row-level security (created by the migrations; its
# dev password is set there — rotate it outside local dev).
DATABASE_URL=postgresql://helio_app:helio_app@localhost:5432/helio

# Admin connection [required for migrate/seed]. Owns the schema, bypasses RLS.
DATABASE_ADMIN_URL=postgresql://helio:helio_dev_password@localhost:5432/helio

# ── Public API gateway (apps/api) ───────────────────────────────────────
# Authenticated with per-organization API keys minted in Settings; no
# gateway-wide secret to configure.
API_PORT=4000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_S=60

# ── Redis (compose service: redis) ─────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Event ingestion (apps/ingest — needs the full profile) ─────────────
INGEST_PORT=4100
# Comma-separated Kafka-protocol brokers (Redpanda in the default stack).
KAFKA_BROKERS=localhost:19092
EVENTS_TOPIC=helio.events.v1
# HTTP interface of ClickHouse (credentials shared with the section below).
CLICKHOUSE_URL=http://localhost:8123
# Per-workspace event budget (requests per window).
INGEST_RATE_LIMIT_MAX=600
INGEST_RATE_LIMIT_WINDOW_S=60
# Run the bus→ClickHouse sink inside the ingest process (single-box default).
INGEST_SINK_ENABLED=true

# ── Engagement tracking (apps/tracking — needs the full profile) ───────
TRACKING_PORT=4200
# [required] HMAC key binding click-redirect targets to their send (min 24 chars).
# Generate one:  openssl rand -hex 24
TRACKING_SECRET=change-me-tracking-hmac-secret-48hex
# Public base URL senders embed in pixel/click links.
PUBLIC_TRACKING_URL=http://localhost:4200

# ── Campaign delivery (apps/workers — needs the full profile) ──────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# [required] HMAC key for stateless unsubscribe tokens (min 24 chars).
# Generate one:  openssl rand -hex 24
UNSUBSCRIBE_SECRET=change-me-unsubscribe-hmac-secret-48hex
# Optional: sign journey webhook payloads (x-helio-signature, HMAC-SHA256).
# WEBHOOK_SIGNING_SECRET=

# ── Web Push (apps/workers send_push node; SDK subscribePush) ───────────
# VAPID keys — generate with: npx web-push generate-vapid-keys
# Push nodes no-op until both are set.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@helio.local

# ── SMS via Twilio (apps/workers send_sms node) ─────────────────────────
# From the Twilio console; send_sms nodes no-op until all three are set.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+15555550100

# ── WhatsApp via the Cloud API (apps/workers send_whatsapp node) ─────────
# From the Meta app; send_whatsapp nodes no-op until both are set.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# ── Intelligence / AI copilot (apps/intelligence) ──────────────────────
# Provider-agnostic LLM gateway. Pick ONE provider; the copilot is
# scoped to your own organization's data only (RAG never crosses tenants).
#
# Supported INTEL_LLM_PROVIDER values and how to connect SECURELY:
#   groq      — Llama 3/3.3 etc. Set INTEL_LLM_API_KEY (https, default).
#   openai    — GPT models.       Set INTEL_LLM_API_KEY (https, default).
#   anthropic — Claude models.    Set INTEL_LLM_API_KEY (https, default).
#   ollama    — self-hosted, OpenAI-compatible. No key needed; defaults to
#               http://localhost:11434/v1 (localhost plaintext is allowed).
#   local     — any self-hosted OpenAI-compatible server (vLLM, LM Studio,
#               llama.cpp). Set INTEL_LLM_BASE_URL; key optional.
#
# Security: keys are read as secrets and never logged. Prompts are refused
# over plaintext HTTP to a NON-local endpoint unless you opt out below.
INTEL_LLM_PROVIDER=groq
INTEL_LLM_MODEL=llama-3.3-70b-versatile
# Never commit a real key. Inject it via the environment / secrets manager.
INTEL_LLM_API_KEY=
# Override the endpoint for self-hosted / proxied models (must be https
# unless local). Example local: http://localhost:11434/v1
# INTEL_LLM_BASE_URL=
INTEL_LLM_TEMPERATURE=0.2
INTEL_LLM_MAX_TOKENS=1024
# Refuse plaintext HTTP to remote hosts. Only disable on a trusted LAN.
INTEL_LLM_REQUIRE_TLS=true
# Copilot RAG reads the user's own org data over the RLS-bound app role
# (NOT the admin connection) — cross-tenant access is impossible at the DB.
INTEL_DATABASE_URL=postgresql://helio_app:helio_app@localhost:5432/helio
# MCP server scope — the single workspace external AI agents may drive.
# Run: uv run python -m helio_intelligence.mcp_server
# INTEL_MCP_ORGANIZATION_ID=
# INTEL_MCP_WORKSPACE_ID=
# Predictive scoring reads behavioral features from ClickHouse (the event
# store). Defaults match the compose stack; the password is a SecretStr.
INTEL_CLICKHOUSE_URL=http://localhost:8123
INTEL_CLICKHOUSE_USER=helio
INTEL_CLICKHOUSE_PASSWORD=helio_dev_password
INTEL_CLICKHOUSE_DATABASE=helio
# Event names that count as a conversion (the positive label for the
# lead-scoring model). JSON array; names are validated before use in SQL.
# INTEL_SCORING_CONVERSION_EVENTS=["Converted","Order Completed","Purchase"]

# ── Billing (Stripe — hosted deployments only; optional) ──────────────────
# Self-hosted Helio is UNLIMITED and unmetered; leave these blank. When set,
# the API gateway accepts Stripe webhooks (signature-verified) and maps the
# subscription's price to a plan. Get the signing secret from the Stripe CLI
# (`stripe listen`) or the dashboard webhook settings.
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# ── Auth ────────────────────────────────────────────────────────────────
# [required] Session/token signing secret, at least 32 chars.
# Generate one:  openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-generate-a-32-byte-hex-secret-first
# Public origin of the dashboard (used in auth callbacks and emails).
APP_URL=http://localhost:3000
# Sender for transactional mail.
MAIL_FROM="Helio <no-reply@helio.local>"
# Per-replica abuse damping on the dashboard's public endpoints (hosted
# forms, booking pages, widget/in-app delivery, SCIM). Leave on; disable
# only for load testing. (default: true)
PUBLIC_RATE_LIMITS_ENABLED=true

# ── Full profile (compose profile: full) ───────────────────────────────
CLICKHOUSE_USER=helio
CLICKHOUSE_PASSWORD=helio_dev_password
CLICKHOUSE_DB=helio
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
REDPANDA_KAFKA_PORT=19092
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
MINIO_ROOT_USER=helio
MINIO_ROOT_PASSWORD=helio_dev_password
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003

# ── Observability (compose profile: observability) ─────────────────────
# Point services at the collector to enable tracing (off when unset).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# LOG_LEVEL=info

# ── Email (dev: Mailpit catches everything — no real mail is sent) ─────
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
