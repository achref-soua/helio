# ──────────────────────────────────────────────────────────────────────
# Helio environment configuration
#
# Copy to `.env` and adjust:   cp .env.example .env
#
# Every variable read by any Helio service is documented here, in the
# same PR that introduces it. Variables marked [required] have no
# default and make the owning service fail fast at startup.
# ──────────────────────────────────────────────────────────────────────

# Node environment: development | test | production  (default: development)
# NODE_ENV=development

# ── PostgreSQL (compose service: postgres) ─────────────────────────────
# Credentials for the local container; change for any non-dev deployment.
POSTGRES_USER=helio
POSTGRES_PASSWORD=helio_dev_password
POSTGRES_DB=helio
POSTGRES_PORT=5432

# Runtime connection [required by app services]. Uses the helio_app role,
# which is subject to row-level security (created by the migrations; its
# dev password is set there — rotate it outside local dev).
DATABASE_URL=postgresql://helio_app:helio_app@localhost:5432/helio

# Admin connection [required for migrate/seed]. Owns the schema, bypasses RLS.
DATABASE_ADMIN_URL=postgresql://helio:helio_dev_password@localhost:5432/helio

# ── Redis (compose service: redis) ─────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Email (dev: Mailpit catches everything — no real mail is sent) ─────
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025
