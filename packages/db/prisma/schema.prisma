generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs live outside the schema (Prisma 7):
//  - Migrate/Studio use the admin adapter from prisma.config.ts
//    (DATABASE_ADMIN_URL — owns the schema, bypasses RLS).
//  - Runtime clients are constructed with a driver adapter over
//    DATABASE_URL (helio_app role, subject to RLS).
datasource db {
  provider = "postgresql"
}

/// Tenant root. Better-Auth's organization plugin owns the auth-facing
/// fields; domain tables hang off it and are isolated by RLS.
model Organization {
  id        String   @id
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")

  workspaces   Workspace[]
  auditLogs    AuditLog[]
  members      Member[]
  invitations  Invitation[]
  contacts     Contact[]
  contactLists ContactList[]
  writeKeys    WriteKey[]
  segments     Segment[]

  @@map("organization")
}

/// A working environment inside an organization (e.g. "Production",
/// "Sandbox"). Most product objects will belong to a workspace.
model Workspace {
  id             String   @id
  organizationId String   @map("organization_id")
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]
  contacts     Contact[]
  contactLists ContactList[]
  writeKeys    WriteKey[]
  segments     Segment[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("workspace")
}

/// Append-only audit trail. Every security-relevant action lands here.
model AuditLog {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String?  @map("workspace_id")
  actorId        String?  @map("actor_id")
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  ip             String?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_log")
}

/// Deliverability state of a contact. Anything other than ACTIVE is
/// suppressed from sending — enforced in the delivery layer.
enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED

  @@map("contact_status")
}

/// A person in the CDP. Workspace-scoped; the org id is denormalized so
/// the standard RLS policy applies directly.
model Contact {
  id             String        @id
  organizationId String        @map("organization_id")
  workspaceId    String        @map("workspace_id")
  email          String
  firstName      String?       @map("first_name")
  lastName       String?       @map("last_name")
  attributes     Json          @default("{}")
  status         ContactStatus @default(ACTIVE)
  source         String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  listMembers  ContactListMember[]

  @@unique([workspaceId, email])
  @@index([organizationId])
  @@index([workspaceId, createdAt])
  @@map("contact")
}

/// A static list of contacts (dynamic segments are a separate concept).
model ContactList {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members      ContactListMember[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("contact_list")
}

model ContactListMember {
  listId         String   @map("list_id")
  contactId      String   @map("contact_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
  @@index([organizationId])
  @@map("contact_list_member")
}

/// A dynamic audience: a stored AND/OR rule tree (shape owned by
/// @helio/core's segmentRuleSchema) compiled to a contact predicate at
/// query time, so membership is always live.
model Segment {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  description    String?
  rule           Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("segment")
}

/// Workspace-scoped credential for the event ingestion endpoint. The
/// value is a public-ish client-side token (it ships in browser code),
/// so it only grants writes into its own workspace's event stream.
model WriteKey {
  id             String    @id
  organizationId String    @map("organization_id")
  workspaceId    String    @map("workspace_id")
  key            String    @unique
  name           String
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workspaceId])
  @@map("write_key")
}

// ───────────────────────── Better-Auth tables ─────────────────────────
// Owned by the auth kernel (admin connection; ADR-0004). The RLS app role
// has no grants on these — see the auth_rls_lockdown migration. Shapes
// follow Better-Auth 1.6 (core + organization, twoFactor, apiKey plugins).

model User {
  id               String    @id
  name             String
  email            String    @unique
  emailVerified    Boolean   @default(false) @map("email_verified")
  image            String?
  twoFactorEnabled Boolean?  @map("two_factor_enabled")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  sessions    Session[]
  accounts    Account[]
  members     Member[]
  invitations Invitation[]
  twofactors  TwoFactor[]
  apikeys     Apikey[]

  @@map("user")
}

model Session {
  id                     String   @id
  expiresAt              DateTime @map("expires_at")
  token                  String   @unique
  ipAddress              String?  @map("ip_address")
  userAgent              String?  @map("user_agent")
  userId                 String   @map("user_id")
  activeOrganizationId   String?  @map("active_organization_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model Member {
  id             String   @id
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String   @id
  organizationId String   @map("organization_id")
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  inviterId      String   @map("inviter_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String @map("backup_codes")
  userId      String @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor")
}

model Apikey {
  id                  String    @id
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String    @map("user_id")
  refillInterval      Int?      @map("refill_interval")
  refillAmount        Int?      @map("refill_amount")
  lastRefillAt        DateTime? @map("last_refill_at")
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(true) @map("rate_limit_enabled")
  rateLimitTimeWindow Int?      @map("rate_limit_time_window")
  rateLimitMax        Int?      @map("rate_limit_max")
  requestCount        Int       @default(0) @map("request_count")
  remaining           Int?
  lastRequest         DateTime? @map("last_request")
  expiresAt           DateTime? @map("expires_at")
  permissions         String?
  metadata            String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@map("apikey")
}
