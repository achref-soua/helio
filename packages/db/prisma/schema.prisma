generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Connection URLs live outside the schema (Prisma 7):
//  - Migrate/Studio use the admin adapter from prisma.config.ts
//    (DATABASE_ADMIN_URL — owns the schema, bypasses RLS).
//  - Runtime clients are constructed with a driver adapter over
//    DATABASE_URL (helio_app role, subject to RLS).
datasource db {
  provider = "postgresql"
}

/// Tenant root. Better-Auth's organization plugin owns the auth-facing
/// fields; domain tables hang off it and are isolated by RLS.
model Organization {
  id         String   @id
  name       String
  slug       String   @unique
  logo       String?
  metadata   String?
  /// White-label display name shown in the dashboard and on hosted pages
  /// (falls back to the product name when unset).
  brandName  String?  @map("brand_name")
  /// White-label accent color as a #rrggbb hex; applied as the primary token.
  brandColor String?  @map("brand_color")
  createdAt  DateTime @default(now()) @map("created_at")

  workspaces        Workspace[]
  auditLogs         AuditLog[]
  members           Member[]
  invitations       Invitation[]
  contacts          Contact[]
  contactLists      ContactList[]
  writeKeys         WriteKey[]
  segments          Segment[]
  emailTemplates    EmailTemplate[]
  emailSends        EmailSend[]
  campaigns         Campaign[]
  journeys          Journey[]
  forms             Form[]
  scoringRules      ScoringRule[]
  pushSubscriptions PushSubscription[]
  pipelines         Pipeline[]
  pipelineStages    PipelineStage[]
  deals             Deal[]
  tasks             Task[]
  ssoProviders      SsoProvider[]
  scimToken         ScimToken?
  gatewayApiKeys    GatewayApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  bookingPages      BookingPage[]
  meetings          Meeting[]
  integrations      Integration[]
  supportTickets    SupportTicket[]
  sendingDomains    SendingDomain[]
  landingPages      LandingPage[]
  widgets             Widget[]
  inAppMessages       InAppMessage[]
  inAppDeliveries     InAppDelivery[]
  providerCredentials ProviderCredential[]

  @@map("organization")
}

/// Which third-party surface a credential connects (ADR-0019).
enum ProviderCredentialKind {
  EMAIL_SMTP
  EMAIL_POSTMARK
  EMAIL_RESEND
  EMAIL_MAILGUN
  SMS_TWILIO
  WHATSAPP_CLOUD
  LLM
  CHURN_ENDPOINT
  IMPORT_HUBSPOT
  IMPORT_MAILCHIMP
  IMPORT_KLAVIYO
}

enum CredentialStatus {
  UNVERIFIED
  VERIFIED
  FAILED
}

/// A per-organization third-party credential (ADR-0019). Non-secret
/// connection config lives in `config`; secret fields are sealed into
/// `secrets` as enc:v1 envelopes (AES-256-GCM under HELIO_ENCRYPTION_KEY)
/// and are NEVER selected by read paths — masked display comes from
/// `secretsMeta` ({ field: { last4, setAt } }, captured at write time).
model ProviderCredential {
  id             String                 @id
  organizationId String                 @map("organization_id")
  kind           ProviderCredentialKind
  name           String
  config         Json                   @default("{}")
  secrets        Json                   @default("{}")
  secretsMeta    Json                   @default("{}") @map("secrets_meta")
  status         CredentialStatus       @default(UNVERIFIED)
  lastVerifiedAt DateTime?              @map("last_verified_at")
  lastError      String?                @map("last_error")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kind, name])
  @@index([organizationId])
  @@map("provider_credential")
}

/// A working environment inside an organization (e.g. "Production",
/// "Sandbox"). Most product objects will belong to a workspace.
model Workspace {
  id             String   @id
  organizationId String   @map("organization_id")
  name           String
  slug           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditLogs         AuditLog[]
  contacts          Contact[]
  contactLists      ContactList[]
  writeKeys         WriteKey[]
  segments          Segment[]
  emailTemplates    EmailTemplate[]
  emailSends        EmailSend[]
  campaigns         Campaign[]
  journeys          Journey[]
  forms             Form[]
  scoringRules      ScoringRule[]
  pushSubscriptions PushSubscription[]
  pipelines         Pipeline[]
  deals             Deal[]
  tasks             Task[]
  bookingPages      BookingPage[]
  meetings          Meeting[]
  integrations      Integration[]
  sendingDomains    SendingDomain[]
  landingPages      LandingPage[]
  widgets           Widget[]
  inAppMessages     InAppMessage[]
  inAppDeliveries   InAppDelivery[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("workspace")
}

/// Append-only audit trail. Every security-relevant action lands here.
model AuditLog {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String?  @map("workspace_id")
  actorId        String?  @map("actor_id")
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  ip             String?
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_log")
}

/// Deliverability state of a contact. Anything other than ACTIVE is
/// suppressed from sending — enforced in the delivery layer.
enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED

  @@map("contact_status")
}

/// A person in the CDP. Workspace-scoped; the org id is denormalized so
/// the standard RLS policy applies directly.
model Contact {
  id                    String        @id
  organizationId        String        @map("organization_id")
  workspaceId           String        @map("workspace_id")
  email                 String
  /// E.164 phone number for SMS/WhatsApp; null when unknown.
  phone                 String?
  firstName             String?       @map("first_name")
  lastName              String?       @map("last_name")
  attributes            Json          @default("{}")
  /// Rule-based engagement score (see ScoringRule); event-driven.
  score                 Int           @default(0)
  /// AI predictions, recomputed in batches by the intelligence service.
  /// Conversion propensity and churn risk are both probabilities in [0,1];
  /// null until the first run. See apps/intelligence/scoring.
  conversionProbability Float?        @map("conversion_probability")
  churnRisk             Float?        @map("churn_risk")
  predictionModel       String?       @map("prediction_model")
  predictionComputedAt  DateTime?     @map("prediction_computed_at")
  /// Hour of day (0–23, UTC) this contact is most likely to engage,
  /// derived from open/click history; null until computed. Used by
  /// send-time optimization to defer sends to the contact's best hour.
  bestSendHour          Int?          @map("best_send_hour")
  status                ContactStatus @default(ACTIVE)
  source                String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  listMembers       ContactListMember[]
  emailSends        EmailSend[]
  journeyRuns       JourneyRun[]
  pushSubscriptions PushSubscription[]
  deals             Deal[]
  tasks             Task[]
  meetings          Meeting[]
  inAppDeliveries   InAppDelivery[]

  @@unique([workspaceId, email])
  @@index([organizationId])
  @@index([workspaceId, createdAt])
  /// Bounce/complaint webhooks look an address up across all workspaces.
  @@index([email])
  @@map("contact")
}

/// A static list of contacts (dynamic segments are a separate concept).
model ContactList {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members      ContactListMember[]
  campaigns    Campaign[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("contact_list")
}

model ContactListMember {
  listId         String   @map("list_id")
  contactId      String   @map("contact_id")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@index([contactId])
  @@index([organizationId])
  @@map("contact_list_member")
}

/// A dynamic audience: a stored AND/OR rule tree (shape owned by
/// @helio/core's segmentRuleSchema) compiled to a contact predicate at
/// query time, so membership is always live.
model Segment {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  description    String?
  rule           Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("segment")
}

/// A reusable email: subject + block document (shape owned by
/// @helio/core's emailDocumentSchema), rendered by packages/emails.
model EmailTemplate {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  subject        String
  document       Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("email_template")
}

/// Workspace-scoped credential for the event ingestion endpoint. The
/// value is a public-ish client-side token (it ships in browser code),
/// so it only grants writes into its own workspace's event stream.
model WriteKey {
  id             String    @id
  organizationId String    @map("organization_id")
  workspaceId    String    @map("workspace_id")
  key            String    @unique
  name           String
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workspaceId])
  @@map("write_key")
}

/// Lifecycle of a one-shot email campaign.
enum CampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED

  @@map("campaign_status")
}

/// A one-shot email blast to a segment or list, executed durably by the
/// campaign workflow (apps/workers, ADR-0011).
model Campaign {
  id                  String         @id
  organizationId      String         @map("organization_id")
  workspaceId         String         @map("workspace_id")
  name                String
  templateId          String         @map("template_id")
  /// Optional subject-line A/B test: template.subject is variant A.
  subjectB            String?        @map("subject_b")
  /// Autonomous winner selection: send both subjects to a test slice,
  /// wait, then send the statistically-better subject to the rest.
  abAutoWinner        Boolean        @default(false) @map("ab_auto_winner")
  /// Percent of the audience in the test slice (rest is the holdout).
  abTestPercent       Int?           @map("ab_test_percent")
  /// How long to gather opens before deciding the winner.
  abTestWindowSeconds Int?           @map("ab_test_window_seconds")
  /// The decided winner ('a' | 'b') and when, once the test concludes.
  abWinner            String?        @map("ab_winner")
  abDecidedAt         DateTime?      @map("ab_decided_at")
  /// Exactly one audience source: a dynamic segment or a static list.
  segmentId           String?        @map("segment_id")
  listId              String?        @map("list_id")
  status              CampaignStatus @default(DRAFT)
  error               String?
  sentAt              DateTime?      @map("sent_at")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template     EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  segment      Segment?      @relation(fields: [segmentId], references: [id], onDelete: Restrict)
  list         ContactList?  @relation(fields: [listId], references: [id], onDelete: Restrict)
  sends        EmailSend[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("campaign")
}

/// Delivery state of an email send. The send pipeline considers
/// anything but ACTIVE contacts suppressed before creating one.
enum EmailSendStatus {
  QUEUED
  SENT
  FAILED

  @@map("email_send_status")
}

/// One email to one contact. The id doubles as the public tracking
/// token in pixel/click URLs, so it must stay unguessable-enough
/// (time-ordered random suffix) and leak nothing on its own.
model EmailSend {
  id             String          @id
  organizationId String          @map("organization_id")
  workspaceId    String          @map("workspace_id")
  contactId      String          @map("contact_id")
  campaignId     String?         @map("campaign_id")
  email          String
  subject        String
  /// A/B variant this send received ('a' or 'b'), when testing.
  variant        String?
  status         EmailSendStatus @default(QUEUED)
  error          String?
  sentAt         DateTime?       @map("sent_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  /// One send per contact per campaign — activity retries cannot double-send.
  @@unique([campaignId, contactId])
  @@index([organizationId])
  @@index([workspaceId, createdAt])
  @@map("email_send")
}

/// Lifecycle of an automation journey.
enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED

  @@map("journey_status")
}

/// State of one contact's pass through a journey.
enum JourneyRunStatus {
  RUNNING
  COMPLETED
  FAILED

  @@map("journey_run_status")
}

/// An automation: a validated DAG (shape owned by @helio/core's
/// journeyDefinitionSchema) executed durably per contact (ADR-0012).
model Journey {
  id             String        @id
  organizationId String        @map("organization_id")
  workspaceId    String        @map("workspace_id")
  name           String
  status         JourneyStatus @default(DRAFT)
  definition     Json
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs         JourneyRun[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@index([workspaceId, status])
  @@map("journey")
}

/// One contact's enrollment. Also the re-entry guard: a RUNNING row
/// blocks duplicate enrollment of the same contact.
model JourneyRun {
  id             String           @id
  organizationId String           @map("organization_id")
  journeyId      String           @map("journey_id")
  contactId      String           @map("contact_id")
  status         JourneyRunStatus @default(RUNNING)
  error          String?
  startedAt      DateTime         @default(now()) @map("started_at")
  completedAt    DateTime?        @map("completed_at")

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([journeyId, contactId, status])
  @@index([organizationId])
  @@map("journey_run")
}

/// A hosted signup form. Phase 1 keeps the fields fixed (email +
/// first name); the drag-and-drop form builder is a Phase 2 feature.
model Form {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  /// Shown as the page heading on the hosted form.
  title          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("form")
}

/// Event-driven scoring: when a tracked event matches, the contact's
/// score moves by `points`. Applied by the worker's event consumer.
model ScoringRule {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  event          String
  points         Int
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, event])
  @@index([organizationId])
  @@map("scoring_rule")
}

/// A browser Web Push subscription (VAPID). Linked to a contact when the
/// SDK has identified one; endpoint is globally unique (the browser's
/// push service URL). Stale endpoints are pruned on 404/410 at send time.
model PushSubscription {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  contactId      String?  @map("contact_id")
  endpoint       String   @unique
  p256dh         String
  auth           String
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([workspaceId])
  @@index([contactId])
  @@map("push_subscription")
}

// ───────────────────────── Better-Auth tables ─────────────────────────
// Owned by the auth kernel (admin connection; ADR-0004). The RLS app role
// has no grants on these — see the auth_rls_lockdown migration. Shapes
// follow Better-Auth 1.6 (core + organization, twoFactor, apiKey plugins).

model User {
  id               String   @id
  name             String
  email            String   @unique
  emailVerified    Boolean  @default(false) @map("email_verified")
  image            String?
  twoFactorEnabled Boolean? @map("two_factor_enabled")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  sessions     Session[]
  accounts     Account[]
  members      Member[]
  invitations  Invitation[]
  twofactors   TwoFactor[]
  apikeys      Apikey[]
  ssoProviders SsoProvider[]

  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime @map("expires_at")
  token                String   @unique
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  userId               String   @map("user_id")
  activeOrganizationId String?  @map("active_organization_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model Member {
  id             String   @id
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String   @id
  organizationId String   @map("organization_id")
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  inviterId      String   @map("inviter_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String @map("backup_codes")
  userId      String @map("user_id")
  /// False between enrollment and the first successful TOTP verification —
  /// Better-Auth 1.6 only activates 2FA once a code proves the enrollment.
  /// Defaults true so any pre-1.6 row keeps working.
  verified    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor")
}

model Apikey {
  id                  String    @id
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String    @map("user_id")
  refillInterval      Int?      @map("refill_interval")
  refillAmount        Int?      @map("refill_amount")
  lastRefillAt        DateTime? @map("last_refill_at")
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(true) @map("rate_limit_enabled")
  rateLimitTimeWindow Int?      @map("rate_limit_time_window")
  rateLimitMax        Int?      @map("rate_limit_max")
  requestCount        Int       @default(0) @map("request_count")
  remaining           Int?
  lastRequest         DateTime? @map("last_request")
  expiresAt           DateTime? @map("expires_at")
  permissions         String?
  metadata            String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@map("apikey")
}

/// Enterprise single sign-on connection (Better-Auth SSO plugin). Like the
/// rest of the auth domain this table is reached only through the admin
/// client; the RLS app role is denied access entirely, so the OIDC client
/// secret held in `oidc_config` never lives in a tenant-readable table. A
/// provider is bound to one organization — users who authenticate through
/// it are provisioned into that org (see ADR-0013).
model SsoProvider {
  id             String  @id
  issuer         String
  domain         String
  oidcConfig     String? @map("oidc_config")
  samlConfig     String? @map("saml_config")
  userId         String  @map("user_id")
  providerId     String  @unique @map("provider_id")
  organizationId String? @map("organization_id")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("sso_provider")
}

/// Per-organization SCIM 2.0 bearer token (one per org). Auth-domain like
/// the SSO providers: only the token's SHA-256 hash is stored, and the
/// table is walled off from the RLS app role (see ADR-0014). An IdP
/// presents the plaintext as `Authorization: Bearer` to `/scim/v2`.
model ScimToken {
  id             String    @id
  organizationId String    @unique @map("organization_id")
  tokenHash      String    @unique @map("token_hash")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastUsedAt     DateTime? @map("last_used_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("scim_token")
}

/// Per-organization API key for the public REST gateway (ADR-0015). Unlike
/// the SSO/SCIM credentials this is an RLS *domain* table: the gateway reads
/// it through the unprivileged app role, scoped to the org embedded in the
/// presented key, so it never needs an admin connection. Only the SHA-256
/// hash is stored.
model GatewayApiKey {
  id             String    @id
  organizationId String    @map("organization_id")
  name           String
  keyHash        String    @unique @map("key_hash")
  prefix         String
  createdAt      DateTime  @default(now()) @map("created_at")
  lastUsedAt     DateTime? @map("last_used_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("gateway_api_key")
}

// ── CRM-lite (deals & pipelines) ───────────────────────────────────────

/// How a pipeline stage counts for reporting: open deals are in flight,
/// won/lost are terminal outcomes. A pipeline has exactly the stages its
/// workspace configures, in `position` order.
enum StageKind {
  OPEN
  WON
  LOST

  @@map("stage_kind")
}

enum DealStatus {
  OPEN
  WON
  LOST

  @@map("deal_status")
}

/// A sales pipeline (e.g. "New business"). Workspace-scoped; isolated by
/// the standard RLS policy on organization_id.
model Pipeline {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  /// Default pipeline for the workspace; new deals land here.
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@unique([workspaceId, name])
  @@index([organizationId])
  @@map("pipeline")
}

/// One ordered column of a pipeline. The org id is denormalized so the
/// standard RLS policy applies without a join.
model PipelineStage {
  id             String    @id
  organizationId String    @map("organization_id")
  workspaceId    String    @map("workspace_id")
  pipelineId     String    @map("pipeline_id")
  name           String
  /// Sort order within the pipeline (0-based).
  position       Int
  kind           StageKind @default(OPEN)
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId])
  @@index([pipelineId, position])
  @@map("pipeline_stage")
}

/// A deal/opportunity moving through a pipeline. Value is stored in minor
/// units (cents) to avoid float drift. Optionally linked to a contact and
/// owned by a workspace member (the auth user id).
model Deal {
  id             String     @id
  organizationId String     @map("organization_id")
  workspaceId    String     @map("workspace_id")
  pipelineId     String     @map("pipeline_id")
  stageId        String     @map("stage_id")
  title          String
  /// Amount in minor units (e.g. cents); pair with `currency`.
  valueCents     Int        @default(0) @map("value_cents")
  currency       String     @default("USD")
  status         DealStatus @default(OPEN)
  /// Sort order within the stage column (0-based).
  position       Int        @default(0)
  contactId      String?    @map("contact_id")
  /// The owning member's auth user id (no hard FK across the auth split).
  ownerId        String?    @map("owner_id")
  closedAt       DateTime?  @map("closed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage        PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  tasks        Task[]

  @@index([organizationId])
  @@index([workspaceId, stageId, position])
  @@map("deal")
}

enum TaskStatus {
  OPEN
  DONE

  @@map("task_status")
}

enum TaskType {
  TODO
  CALL
  EMAIL
  MEETING

  @@map("task_type")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH

  @@map("task_priority")
}

/// A CRM to-do — a generic task, call, email, or meeting — optionally tied
/// to a contact and/or a deal and assigned to a workspace member. Workspace-
/// scoped and isolated by the standard RLS policy on organization_id.
model Task {
  id             String       @id
  organizationId String       @map("organization_id")
  workspaceId    String       @map("workspace_id")
  title          String
  /// Free-form detail shown under the title.
  notes          String?
  type           TaskType     @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(OPEN)
  /// When the task is due; null means no due date.
  dueAt          DateTime?    @map("due_at")
  /// Set when the task is marked done; cleared when it is reopened.
  completedAt    DateTime?    @map("completed_at")
  contactId      String?      @map("contact_id")
  dealId         String?      @map("deal_id")
  /// The assignee's auth user id (no hard FK across the auth split).
  ownerId        String?      @map("owner_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([workspaceId, status, dueAt])
  @@map("task")
}

/// An outbound webhook subscription. Helio POSTs a signed JSON payload to
/// `url` whenever one of the subscribed `events` occurs in the org.
/// Org-scoped (like API keys) and isolated by the standard RLS policy.
model WebhookEndpoint {
  id             String   @id
  organizationId String   @map("organization_id")
  url            String
  description    String?
  /// HMAC-SHA256 signing secret (whsec_…); revealed to the operator once.
  secret         String
  /// Subscribed event keys — see WEBHOOK_EVENTS in @helio/core.
  events         String[]
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("webhook_endpoint")
}

/// A public booking page (one per slug per workspace). Invitees pick an open
/// slot computed from `availability` minus already-booked meetings. Workspace
/// scoped and isolated by the standard RLS policy; the public page reads it
/// through the admin client by slug (the slug is the capability).
model BookingPage {
  id              String   @id
  organizationId  String   @map("organization_id")
  workspaceId     String   @map("workspace_id")
  title           String
  description     String?
  durationMinutes Int      @default(30) @map("duration_minutes")
  /// IANA timezone the availability is expressed in (e.g. America/New_York).
  timezone        String   @default("UTC")
  /// Weekly availability: array of { weekday: 0-6 (Sun=0), start, end } with
  /// start/end as minutes from midnight in `timezone`. See @helio/core.
  availability    Json     @default("[]")
  /// Minimum gap enforced after each meeting, in minutes.
  bufferMinutes   Int      @default(0) @map("buffer_minutes")
  /// The hosting member's auth user id; a booked meeting creates a task for it.
  ownerId         String?  @map("owner_id")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  meetings     Meeting[]

  @@index([organizationId])
  @@index([workspaceId])
  @@map("booking_page")
}

enum MeetingStatus {
  BOOKED
  CANCELED

  @@map("meeting_status")
}

/// A booked meeting on a booking page. `startAt` is an absolute UTC instant;
/// the unique (bookingPageId, startAt) makes double-booking impossible even
/// under a race. Optionally linked to the contact created from the invitee.
model Meeting {
  id              String        @id
  organizationId  String        @map("organization_id")
  workspaceId     String        @map("workspace_id")
  bookingPageId   String        @map("booking_page_id")
  startAt         DateTime      @map("start_at")
  durationMinutes Int           @map("duration_minutes")
  inviteeEmail    String        @map("invitee_email")
  inviteeName     String?       @map("invitee_name")
  contactId       String?       @map("contact_id")
  status          MeetingStatus @default(BOOKED)
  createdAt       DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookingPage  BookingPage  @relation(fields: [bookingPageId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([bookingPageId, startAt])
  @@index([organizationId])
  @@index([workspaceId, startAt])
  @@map("meeting")
}

enum IntegrationProvider {
  SHOPIFY
  SALESFORCE

  @@map("integration_provider")
}

/// A connection to an external platform. Shopify uses `secret` to verify
/// inbound webhooks and `externalId` to resolve the shop; Salesforce stores
/// an access token in `secret`. Workspace-scoped and RLS-isolated; the inbound
/// webhook resolves the org through the admin client by (provider, externalId).
model Integration {
  id             String              @id
  organizationId String              @map("organization_id")
  workspaceId    String              @map("workspace_id")
  provider       IntegrationProvider
  /// External identifier used to route inbound calls (e.g. the Shopify shop
  /// domain). Unique per provider so a shop maps to exactly one org.
  externalId     String?             @map("external_id")
  /// Webhook-signing secret (Shopify) or access token (Salesforce).
  secret         String?
  /// Provider-specific configuration as JSON.
  config         Json                @default("{}")
  enabled        Boolean             @default(true)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@unique([provider, externalId])
  @@index([organizationId])
  @@map("integration")
}

enum SupportKind {
  BUG
  FEEDBACK
  QUESTION

  @@map("support_kind")
}

enum SupportStatus {
  OPEN
  RESOLVED

  @@map("support_status")
}

/// A support / bug report filed from inside the app. Org-scoped and isolated
/// by the standard RLS policy; admins triage and resolve them.
model SupportTicket {
  id             String        @id
  organizationId String        @map("organization_id")
  /// The reporting member's auth user id.
  reporterId     String?       @map("reporter_id")
  kind           SupportKind   @default(BUG)
  subject        String
  body           String
  /// The page the report was filed from, captured for context.
  url            String?
  status         SupportStatus @default(OPEN)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("support_ticket")
}

enum DomainStatus {
  PENDING
  VERIFIED

  @@map("domain_status")
}

/// A sending domain in the deliverability wizard. Helio generates the DKIM
/// key pair on add; the operator publishes the SPF/DKIM/DMARC records and
/// verifies them by DNS lookup. Workspace-scoped and RLS-isolated.
model SendingDomain {
  id             String       @id
  organizationId String       @map("organization_id")
  workspaceId    String       @map("workspace_id")
  domain         String
  dkimSelector   String       @default("helio") @map("dkim_selector")
  /// Base64 DER of the DKIM public key (published in DNS).
  dkimPublicKey  String       @map("dkim_public_key")
  /// PEM private key used to sign outgoing mail; never leaves the server.
  dkimPrivateKey String       @map("dkim_private_key")
  /// SPF include for the sending provider (e.g. amazonses.com).
  spfInclude     String?      @map("spf_include")
  status         DomainStatus @default(PENDING)
  verifiedAt     DateTime?    @map("verified_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domain])
  @@index([organizationId])
  @@map("sending_domain")
}

/// A hosted, block-based landing page. Public at /p/<id> when published;
/// a form block captures contacts into the page's workspace. Workspace-
/// scoped and isolated by the standard RLS policy.
model LandingPage {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  title          String
  /// Ordered blocks — see @helio/core landingDocumentSchema.
  blocks         Json     @default("[]")
  published      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workspaceId])
  @@map("landing_page")
}

enum WidgetType {
  BANNER
  POPUP

  @@map("widget_type")
}

/// An on-site widget (banner or popup) served to a visitor's browser by the
/// public embed, keyed off the workspace write key. Workspace-scoped and
/// isolated by the standard RLS policy.
model Widget {
  id             String     @id
  organizationId String     @map("organization_id")
  workspaceId    String     @map("workspace_id")
  name           String
  type           WidgetType @default(BANNER)
  title          String
  body           String
  ctaLabel       String?    @map("cta_label")
  ctaUrl         String?    @map("cta_url")
  active         Boolean    @default(false)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([workspaceId, active])
  @@map("widget")
}

/// In-app message content shown inside the customer's own product to
/// identified visitors. Journeys queue a per-contact InAppDelivery; the
/// tracking SDK fetches unseen deliveries for the current identity.
model InAppMessage {
  id             String   @id
  organizationId String   @map("organization_id")
  workspaceId    String   @map("workspace_id")
  name           String
  title          String
  body           String
  ctaLabel       String?  @map("cta_label")
  ctaUrl         String?  @map("cta_url")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries   InAppDelivery[]

  @@index([organizationId])
  @@index([workspaceId, active])
  @@map("in_app_message")
}

/// One queued in-app message for one contact. Created when a journey hits a
/// send_in_app node; cleared (seenAt set) when the SDK reports it displayed.
model InAppDelivery {
  id             String    @id
  organizationId String    @map("organization_id")
  workspaceId    String    @map("workspace_id")
  messageId      String    @map("message_id")
  contactId      String    @map("contact_id")
  seenAt         DateTime? @map("seen_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  message      InAppMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId, seenAt])
  @@map("in_app_delivery")
}
