{
  "name": "@helio/sdk-js",
  "version": "0.0.0",
  "private": true,
  "description": "Helio JS/TS SDK: browser event tracking (track/identify/page) and a typed REST client for the public API gateway.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./rest": "./src/rest.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "generate": "openapi-typescript ../../apps/api/openapi.json -o src/openapi.d.ts"
  },
  "devDependencies": {
    "@helio/config": "workspace:*",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
