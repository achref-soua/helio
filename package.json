{
  "name": "helio",
  "version": "2.0.4",
  "private": true,
  "description": "The open-source growth platform — AI-native marketing automation, self-hosted.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/achref-soua/helio.git"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=3",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node -e \"if (!process.env.CI && require('fs').existsSync('.git')) require('child_process').execSync('lefthook install', { stdio: 'inherit' })\""
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@helio/config": "workspace:*",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16"
  }
}
